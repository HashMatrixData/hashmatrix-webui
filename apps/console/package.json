{
  "name": "@hashmatrix/console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test-storybook:ci": "concurrently -k -s first -n SB,E2E \"http-server storybook-static --port 6006 --silent\" \"wait-on tcp:127.0.0.1:6006 && test-storybook --url http://127.0.0.1:6006\""
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@hashmatrix/brand": "workspace:*",
    "@hashmatrix/i18n": "workspace:*",
    "@hashmatrix/sdk": "workspace:*",
    "@hashmatrix/theme": "workspace:*",
    "@hashmatrix/ui": "workspace:*",
    "@ant-design/pro-components": "^2.8.10",
    "@antv/g2": "^5.4.8",
    "@antv/g6": "^5.1.1",
    "@antv/s2": "^2.7.2",
    "@antv/x6": "^3.1.7",
    "@tanstack/react-query": "^5.101.0",
    "antd": "^6.4.4",
    "axios": "^1.18.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-oidc-context": "^3.3.1",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "http-server": "^14.1.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "storybook": "^10.4.6",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
